{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/adm", "destination": "/adm.html" },
    { "source": "/adm.html", "destination": "/adm.html" },
    { "source": "/kasir", "destination": "/kasir.html" },
    { "source": "/kasir.html", "destination": "/kasir.html" },
    { "source": "/", "destination": "/kasir.html" }
  ]
}
